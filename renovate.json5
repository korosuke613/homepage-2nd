{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>korosuke613/renovate-config',
  ],
  dependencyDashboard: true,
  dependencyDashboardApproval: true,
  automerge: false,
  packageRules: [
    {
      automerge: false,
      matchPackageNames: [
        '*',
      ],
    },
  ],
  minimumReleaseAge: '7 days',
  schedule: [
    'before 5am on monday',
  ],
  vulnerabilityAlerts: {
    enabled: false,
  },
}
